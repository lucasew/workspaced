+			logger.Info("backup action started", "index", idx+1, "total", len(actions), "name", msg, "kind", act.GetKind())
+
+			if cmdctx.IsDryRun(ctx) {
+				s.Log(fmt.Sprintf("dry-run: skipping %s", msg))
